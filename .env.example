# =============================================================================
# Finance Advisor — environment configuration
# Copy this file to `.env` and fill in the values you need. `.env` is gitignored.
# Educational use only — NOT financial advice.
# =============================================================================

# --- LLM provider --------------------------------------------------------------
# Optional: "anthropic" | "openai" | "none"
# If unset, the app auto-detects from the API keys below. If neither key is set,
# the agent falls back to a built-in keyword router (no external calls).
LLM_PROVIDER=

# Anthropic (preferred if both keys are set)
ANTHROPIC_API_KEY=
# Optional model override (default: claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=

# OpenAI
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=

# --- Flask server --------------------------------------------------------------
# Port the dev server / gunicorn binds to (default: 5000)
PORT=5000
# Set to "0" to disable debug mode for `python -m app.api`
FLASK_DEBUG=1
